# Server
NODE_ENV=development
PORT=4000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/soteria_loto
MONGODB_DB_NAME=soteria_loto

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_REFRESH_SECRET=change_this_too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...

# AWS S3 (or use local storage for dev)
STORAGE_PROVIDER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
AWS_S3_BUCKET=soteria-loto-media

# Local storage (dev only)
LOCAL_UPLOAD_DIR=./uploads

# QR
QR_BASE_URL=http://localhost:3000/q

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Logging
LOG_LEVEL=debug
